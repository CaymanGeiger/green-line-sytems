generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  IC
  ENGINEER
  VIEWER
}

enum TeamMembershipRole {
  OWNER
  MEMBER
}

enum PermissionResource {
  DASHBOARD
  INCIDENT
  SERVICE
  RUNBOOK
  POSTMORTEM
  ACTION_ITEM
  SAVED_VIEW
  SIMULATOR
  TEAM
  TEAM_MEMBER
  TEAM_PERMISSION
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
}

enum ServiceTier {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentSeverity {
  SEV1
  SEV2
  SEV3
  SEV4
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  MITIGATED
  RESOLVED
}

enum IncidentAssigneeRole {
  COMMANDER
  INVESTIGATOR
  COMMS
}

enum TimelineEventType {
  CREATED
  STATUS_CHANGED
  SEVERITY_CHANGED
  NOTE
  DEPLOY_LINKED
  ERROR_SPIKE
  MITIGATED
  RESOLVED
}

enum DeployProvider {
  GITHUB
  GITLAB
  CIRCLECI
  MANUAL
}

enum DeployStatus {
  STARTED
  SUCCEEDED
  FAILED
  ROLLED_BACK
}

enum ErrorProvider {
  SENTRY
  DATADOG
  ROLLBAR
  MANUAL
}

enum ErrorLevel {
  ERROR
  WARNING
  FATAL
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum AlertSource {
  DATADOG
  CLOUDWATCH
  PROMETHEUS
  MANUAL
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AlertStatus {
  TRIGGERED
  ACKED
  RESOLVED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum ActionItemPriority {
  P1
  P2
  P3
}

enum IntegrationProvider {
  SENTRY
  DATADOG
  GITHUB
  SLACK
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  name              String
  passwordHash      String
  role              UserRole            @default(ENGINEER)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  sessions          Session[]
  teamMemberships   TeamMembership[]
  ownedServices     Service[]           @relation("ServiceOwner")
  createdIncidents  Incident[]          @relation("IncidentCreatedBy")
  commandedIncidents Incident[]         @relation("IncidentCommander")
  timelineEvents    IncidentTimelineEvent[]
  incidentAssignees IncidentAssignee[]
  createdRunbooks   Runbook[]
  authoredPostmortems Postmortem[]
  ownedActionItems  ActionItem[]        @relation("ActionItemOwner")
  passwordResetCodes PasswordResetCode[]
  savedViews        SavedView[]
  uiPreferences     UiPreference[]
  sentTeamInvites   TeamInvite[]        @relation("TeamInviteInvitedBy")
  teamPermissions   TeamPermission[]
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Team {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  memberships            TeamMembership[]
  services               Service[]
  incidents              Incident[]
  runbooks               Runbook[]
  integrationCredentials IntegrationCredential[]
  invites                TeamInvite[]
  permissions            TeamPermission[]
}

model TeamMembership {
  id       String             @id @default(cuid())
  userId   String
  teamId   String
  role     TeamMembershipRole @default(MEMBER)
  createdAt DateTime          @default(now())
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model TeamPermission {
  id        String             @id @default(cuid())
  teamId    String
  userId    String
  resource  PermissionResource
  action    PermissionAction
  allowed   Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  team      Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId, resource, action])
  @@index([teamId, userId])
  @@index([userId, resource, action])
}

model Service {
  id           String            @id @default(cuid())
  teamId       String
  name         String
  slug         String
  tier         ServiceTier
  repoUrl      String?
  runbookUrl   String?
  ownerUserId  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  team         Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  owner        User?             @relation("ServiceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  environments Environment[]
  incidents    Incident[]
  deployEvents DeployEvent[]
  errorEvents  ErrorEvent[]
  logEvents    LogEvent[]
  alertEvents  AlertEvent[]
  runbooks     Runbook[]
  dailyMetrics DailyServiceMetric[]

  @@unique([teamId, slug])
  @@index([teamId])
  @@index([ownerUserId])
}

model Environment {
  id         String      @id @default(cuid())
  serviceId  String
  name       String
  createdAt  DateTime    @default(now())
  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  deployEvents DeployEvent[]
  errorEvents ErrorEvent[]
  logEvents   LogEvent[]

  @@unique([serviceId, name])
  @@index([serviceId])
}

model Incident {
  id               String             @id @default(cuid())
  teamId           String
  serviceId        String?
  incidentKey      String             @unique
  title            String
  severity         IncidentSeverity
  status           IncidentStatus
  startedAt        DateTime
  detectedAt       DateTime?
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  summary          String?
  rootCause        String?
  impact           String?
  simulated        Boolean            @default(false)
  createdByUserId  String
  commanderUserId  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  team             Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  service          Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdByUser    User               @relation("IncidentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  commanderUser    User?              @relation("IncidentCommander", fields: [commanderUserId], references: [id], onDelete: SetNull)
  assignees        IncidentAssignee[]
  timelineEvents   IncidentTimelineEvent[]
  alertEvents      AlertEvent[]
  postmortem       Postmortem?

  @@index([status])
  @@index([severity])
  @@index([startedAt])
  @@index([teamId])
  @@index([serviceId])
  @@index([simulated])
}

model IncidentAssignee {
  id         String               @id @default(cuid())
  incidentId String
  userId     String
  role       IncidentAssigneeRole
  incident   Incident             @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([incidentId, userId])
  @@index([userId])
}

model IncidentTimelineEvent {
  id              String            @id @default(cuid())
  incidentId      String
  type            TimelineEventType
  message         String
  metadataJson    Json?
  simulated       Boolean           @default(false)
  createdByUserId String?
  createdAt       DateTime          @default(now())
  incident        Incident          @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdByUser   User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([incidentId, createdAt])
}

model DeployEvent {
  id            String         @id @default(cuid())
  serviceId     String
  environmentId String?
  provider      DeployProvider
  externalId    String?        @unique
  commitSha     String
  commitMessage String?
  branch        String?
  author        String?
  startedAt     DateTime?
  finishedAt    DateTime?
  status        DeployStatus
  simulated     Boolean        @default(false)
  url           String?
  createdAt     DateTime       @default(now())
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  environment   Environment?   @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([startedAt])
  @@index([status])
  @@index([simulated])
}

model ErrorEvent {
  id            String        @id @default(cuid())
  serviceId     String
  environmentId String?
  provider      ErrorProvider
  fingerprint   String
  title         String
  level         ErrorLevel
  firstSeenAt   DateTime
  lastSeenAt    DateTime
  occurrences   Int
  simulated     Boolean       @default(false)
  url           String?
  rawJson       Json?
  createdAt     DateTime      @default(now())
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  environment   Environment?  @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  @@index([serviceId, lastSeenAt])
  @@index([simulated, lastSeenAt])
}

model LogEvent {
  id            String       @id @default(cuid())
  serviceId     String
  environmentId String?
  level         LogLevel
  message       String
  timestamp     DateTime
  traceId       String?
  spanId        String?
  source        String
  simulated     Boolean      @default(false)
  rawJson       Json?
  createdAt     DateTime     @default(now())
  service       Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  @@index([serviceId, timestamp])
  @@index([level, timestamp])
  @@index([simulated, timestamp])
}

model AlertEvent {
  id           String        @id @default(cuid())
  incidentId   String?
  serviceId    String
  source       AlertSource
  alertKey     String
  title        String
  severity     AlertSeverity
  triggeredAt  DateTime
  resolvedAt   DateTime?
  status       AlertStatus
  simulated    Boolean       @default(false)
  payloadJson  Json?
  createdAt    DateTime      @default(now())
  incident     Incident?     @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, triggeredAt])
  @@index([simulated, triggeredAt])
}

model Runbook {
  id              String    @id @default(cuid())
  serviceId       String?
  teamId          String
  title           String
  slug            String
  markdown        String
  tagsJson        Json?
  version         Int
  isActive        Boolean   @default(true)
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  team            Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  service         Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdByUser   User      @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@unique([teamId, slug, version])
  @@index([serviceId])
  @@index([teamId, slug])
}

model Postmortem {
  id                 String     @id @default(cuid())
  incidentId         String     @unique
  authorUserId       String
  whatHappened       String
  impact             String
  rootCause          String
  detectionGaps      String
  actionItemsSummary String
  followUpBy         DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  incident           Incident   @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  authorUser         User       @relation(fields: [authorUserId], references: [id], onDelete: Restrict)
  actionItems        ActionItem[]
}

model ActionItem {
  id          String           @id @default(cuid())
  postmortemId String
  title       String
  description String?
  ownerUserId String?
  dueDate     DateTime?
  status      ActionItemStatus @default(OPEN)
  priority    ActionItemPriority @default(P2)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  postmortem  Postmortem       @relation(fields: [postmortemId], references: [id], onDelete: Cascade)
  ownerUser   User?            @relation("ActionItemOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([dueDate, status])
}

model IntegrationCredential {
  id             String              @id @default(cuid())
  teamId          String
  provider        IntegrationProvider
  encryptedToken  String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  team            Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model DailyServiceMetric {
  id             String   @id @default(cuid())
  serviceId      String
  date           DateTime
  incidentCount  Int      @default(0)
  errorCount     Int      @default(0)
  deployCount    Int      @default(0)
  mttrMinutes    Int      @default(0)
  mttaMinutes    Int      @default(0)
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, date])
  @@index([date])
}

model ApiRateLimitBucket {
  key         String   @id
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model PasswordResetCode {
  id          String   @id @default(cuid())
  userId      String
  nonce       String
  codeHash    String
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model SavedView {
  id          String   @id @default(cuid())
  userId      String
  name        String
  scope       String
  filtersJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope])
}

model UiPreference {
  id            String   @id @default(cuid())
  userId        String
  preferenceKey String
  isOpen        Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, preferenceKey])
  @@index([userId])
}

model TeamInvite {
  id              String             @id @default(cuid())
  teamId           String
  email            String
  role             TeamMembershipRole @default(MEMBER)
  tokenHash        String             @unique
  invitedByUserId  String
  expiresAt        DateTime
  consumedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  team             Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedByUser    User               @relation("TeamInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([teamId, email, consumedAt])
  @@index([email, expiresAt])
}
